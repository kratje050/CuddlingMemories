# Supabase project-instellingen (Project settings > API in het Supabase-dashboard).
# VITE_-variabelen worden in de frontend gebundeld en zijn dus publiek zichtbaar.
# De anon key is daarvoor bedoeld (rechten worden afgedwongen via Row Level Security).
VITE_SUPABASE_URL=https://jouw-project.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-anon-key

# GEHEIM — nooit met VITE_-prefix, nooit in frontend-code gebruiken.
# Alleen instellen als Netlify-omgevingsvariabele voor gebruik in netlify/functions/.
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key
