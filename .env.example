# Supabase project-instellingen (Project settings > API in het Supabase-dashboard).
# VITE_-variabelen worden in de frontend gebundeld en zijn dus publiek zichtbaar.
# De anon key is daarvoor bedoeld (rechten worden afgedwongen via Row Level Security).
VITE_SUPABASE_URL=https://jouw-project.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-anon-key

# GEHEIM — nooit met VITE_-prefix, nooit in frontend-code gebruiken.
# Alleen instellen als Netlify-omgevingsvariabele voor gebruik in netlify/functions/.
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# Mailprovider voor Netlify Functions.
# Resend werkt met EMAIL_API_KEY + EMAIL_FROM_ADDRESS.
# Als alternatief kan Gmail SMTP gebruikt worden met SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASS.
EMAIL_PROVIDER=resend
EMAIL_API_KEY=jouw-mail-api-key
EMAIL_FROM_ADDRESS="Cuddling Memories Fotografie <mail@jouwdomein.nl>"

# Optioneel: Gmail SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ddytuber@gmail.com
SMTP_PASS=jouw-gmail-app-wachtwoord
EMAIL_FROM="Cuddling Memories Fotografie <ddytuber@gmail.com>"

# Cloudflare R2 voor prive-klantgalerijen. Alle waarden zonder VITE_-prefix:
# deze mogen uitsluitend door Netlify Functions worden gelezen.
# Laat CLIENT_GALLERY_STORAGE_PROVIDER op supabase tot de previewtest slaagt.
CLIENT_GALLERY_STORAGE_PROVIDER=supabase
R2_ACCOUNT_ID=jouw-cloudflare-account-id
R2_ACCESS_KEY_ID=jouw-r2-access-key-id
R2_SECRET_ACCESS_KEY=jouw-r2-secret-access-key
R2_BUCKET_NAME=cuddling-memories-media
# Alleen nodig wanneer later een afzonderlijke openbare R2-bucket wordt gebruikt.
R2_PUBLIC_BASE_URL=https://media.jouwdomein.nl
